# ──────────────────────────────────────────────────
# Shiprocket Credentials
# ──────────────────────────────────────────────────
SHIPROCKET_EMAIL=your_email@example.com
SHIPROCKET_PASSWORD=your_password

# ──────────────────────────────────────────────────
# Amazon SP-API Credentials
# ──────────────────────────────────────────────────
AMAZON_CLIENT_ID=your_client_id
AMAZON_CLIENT_SECRET=your_client_secret
AMAZON_REFRESH_TOKEN=your_refresh_token
AMAZON_MARKETPLACE_ID=A21TJRUUN4KGV

# ──────────────────────────────────────────────────
# State file location (relative or absolute)
# ──────────────────────────────────────────────────
STATE_FILE_PATH=./sync_state.json

# ──────────────────────────────────────────────────
# Dry-run mode: set to "true" to skip Amazon submission
# ──────────────────────────────────────────────────
DRY_RUN=true

# ──────────────────────────────────────────────────
# WooCommerce Credentials
# ──────────────────────────────────────────────────
WOOCOMMERCE_STORE_URL=https://yourstore.com
WOOCOMMERCE_CONSUMER_KEY=ck_your_consumer_key
WOOCOMMERCE_CONSUMER_SECRET=cs_your_consumer_secret

# ──────────────────────────────────────────────────
# Optional overrides (defaults shown; see config.py)
# You normally do NOT need to set these — uncomment only to override.
# ──────────────────────────────────────────────────
# Sales channel names as they appear in Shiprocket (persisted in state/DB!)
AMAZON_CHANNEL_NAME=LIRIYA (AMAZON)
WOO_CHANNEL_NAME=LIRIYA (WOOCOMMERCE)
# Platform keys used in the orders database
AMAZON_PLATFORM_KEY=Amazon (LIRIYA)
WOO_PLATFORM_KEY=LIRIYA
# Courier preference order for auto-assignment (comma-separated)
COURIER_PREFERENCE=Delhivery Surface,Delhivery Air,Blue Dart Surface
# Label printer network identity (used for auto-rediscovery)
PRINTER_MAC=e0:bb:9e:83:1a:02
PRINTER_SUBNET=192.168.29.0/24
# HTTP request timeout in seconds
HTTP_TIMEOUT=20
# Financial estimate rates used by the dashboard
ESTIMATED_AMAZON_FEE_RATE=0.25
PAYMENT_GATEWAY_FEE_RATE=0.02
# Token required by the sync dashboard API (empty = disabled)
DASHBOARD_TOKEN=
